{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "deleteOutDir": true,
        "assets": [
            {
                "include": "database/schema.sql",
                "outDir": "dist"
            },
            {
                "include": "**/*.md",
                "outDir": "dist"
            }
        ],
        "watchAssets": true
    }
}
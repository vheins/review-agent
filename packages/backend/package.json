{
  "name": "@review-agent/backend",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "NODE_NO_WARNINGS=1 node --no-warnings --loader ts-node/esm ./src/start.ts",
    "start:continuous": "NODE_NO_WARNINGS=1 node --no-warnings --loader ts-node/esm ./src/start.ts",
    "debug": "nest start --debug --watch",
    "once": "NODE_NO_WARNINGS=1 node --no-warnings --loader ts-node/esm ./src/once.ts",
    "validate-migration": "node --loader ts-node/esm ./src/migration/migration-validator.cli.ts validate",
    "soundboard:beep": "NODE_NO_WARNINGS=1 node --no-warnings --loader ts-node/esm ./src/soundboard-test.ts",
    "soundboard:beep:approved": "NODE_NO_WARNINGS=1 node --no-warnings --loader ts-node/esm ./src/soundboard-test.ts approved",
    "soundboard:beep:rejected": "NODE_NO_WARNINGS=1 node --no-warnings --loader ts-node/esm ./src/soundboard-test.ts rejected"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-ws": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.16",
    "@types/nodemailer": "^7.0.11",
    "blessed": "^0.1.81",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "discord.js": "^14.26.4",
    "execa": "^8.0.1",
    "ffmpeg-static": "^5.3.0",
    "fs-extra": "^11.2.0",
    "globby": "^16.1.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "json2csv": "^6.0.0-alpha.2",
    "nodemailer": "^8.0.2",
    "ora": "^9.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.16",
    "@types/blessed": "^0.1.27",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "ts-node": "^10.9.2"
  }
}

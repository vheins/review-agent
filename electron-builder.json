{
    "appId": "com.prreview.agent",
    "productName": "PR Review Agent",
    "directories": {
        "output": "dist"
    },
    "files": [
        "electron/**/*",
        "src/**/*",
        "context/**/*",
        "agents.md",
        ".env.example",
        "node_modules/**/*"
    ],
    "win": {
        "target": [
            "nsis"
        ],
        "icon": "electron/icon.png"
    },
    "mac": {
        "target": [
            "dmg"
        ],
        "icon": "electron/icon.png"
    },
    "linux": {
        "target": [
            "AppImage",
            "deb"
        ],
        "icon": "electron/icon.png",
        "category": "Development"
    }
}
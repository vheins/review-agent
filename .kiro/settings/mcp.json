{
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@executeautomation/playwright-mcp-server"
            ],
            "env": {},
            "disabled": false,
            "autoApprove": [
                "playwright_navigate",
                "playwright_screenshot",
                "playwright_click",
                "playwright_fill",
                "playwright_select",
                "playwright_hover",
                "playwright_evaluate"
            ]
        }
    }
}
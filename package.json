{
  "name": "pr-review-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "GitHub Pull Request assistant with optional Gemini delegation",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "once": "node src/index.js --once",
    "dry-run": "node src/index.js --once --dry-run",
    "review": "node src/review-pr.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "ui:build": "vite build --config electron/vite.config.mjs",
    "ui:dev": "vite --config electron/vite.config.mjs",
    "test:electron-ui": "yarn ui:build && playwright test",
    "app": "yarn ui:build && electron electron/main.cjs",
    "app:dev": "concurrently -k \"yarn ui:dev\" \"wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.cjs\"",
    "app:dev:win": "yarn app:dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "github",
    "pr",
    "review",
    "automation"
  ],
  "author": {
    "name": "M. Rheza Alfin",
    "email": "m.rheza.alfin@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "acorn": "^8.16.0",
    "better-sqlite3": "^12.6.2",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "cli-spinners": "^3.4.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "execa": "^8.0.1",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.1",
    "json2csv": "^6.0.0-alpha.2",
    "lucide-react": "^0.577.0",
    "markdown-it": "^14.1.1",
    "morgan": "^1.10.1",
    "node-notifier": "^10.0.1",
    "nodemailer": "^8.0.2",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "strip-ansi": "^7.2.0",
    "tailwind-merge": "^3.5.0",
    "terminal-link": "^5.0.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "fast-check": "^4.6.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "3.4.17",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}

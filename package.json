{
  "name": "pr-review-agent-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "yarn workspace @review-agent/backend dev",
    "backend:build": "yarn workspace @review-agent/backend build",
    "backend:start": "yarn workspace @review-agent/backend start",
    "start:bg": "./scripts/start.sh",
    "stop": "./scripts/stop.sh",
    "status": "./scripts/status.sh",
    "logs": "./scripts/logs.sh",
    "logs:tail": "./scripts/logs.sh -f",
    "once": "yarn workspace @review-agent/backend once",
    "start": "./scripts/start-backend.sh",
    "dry-run": "cross-env DRY_RUN=true yarn workspace @review-agent/backend once",
    "soundboard:beep": "yarn workspace @review-agent/backend soundboard:beep",
    "soundboard:beep:approved": "yarn workspace @review-agent/backend soundboard:beep:approved",
    "soundboard:beep:rejected": "yarn workspace @review-agent/backend soundboard:beep:rejected",
    "tts": "yarn workspace @review-agent/backend tts",
    "ui:dev": "yarn workspace @review-agent/ui dev",
    "ui:build": "yarn workspace @review-agent/ui build",
    "desktop:dev": "cross-env NODE_ENV=development API_PORT=30001 VITE_DEV_SERVER_URL=http://127.0.0.1:30002 yarn workspace @review-agent/desktop dev",
    "dev": "./scripts/cleanup.sh && concurrently -k \"yarn backend:dev\" \"wait-on tcp:30001 && yarn ui:dev\" \"wait-on tcp:30002 && yarn desktop:dev\"",
    "test": "vitest run",
    "lint": "eslint \"packages/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,cjs,mjs,json,css,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "resolutions": {
    "tar": "7.5.11",
    "file-type": "21.3.1",
    "@tootallnate/once": "3.0.1"
  },
  "dependencies": {
    "sqlite3": "^6.0.1"
  }
}

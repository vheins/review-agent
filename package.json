{
  "name": "pr-review-agent-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "yarn workspace @review-agent/backend dev",
    "backend:build": "yarn workspace @review-agent/backend build",
    "backend:start": "yarn workspace @review-agent/backend start",
    "ui:dev": "yarn workspace @review-agent/ui dev",
    "ui:build": "yarn workspace @review-agent/ui build",
    "desktop:dev": "cross-env NODE_ENV=development yarn workspace @review-agent/desktop dev",
    "dev": "concurrently -k \"yarn backend:dev\" \"yarn ui:dev\" \"wait-on tcp:5173 && yarn desktop:dev\"",
    "test": "vitest run",
    "lint": "eslint \"packages/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,cjs,mjs,json,css,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4",
    "husky": "^9.1.7"
  }
}
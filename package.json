{
  "name": "pr-review-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "GitHub Pull Request assistant with optional Gemini delegation",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "once": "node src/index.js --once",
    "dry-run": "node src/index.js --once --dry-run",
    "review": "node src/review-pr.js",
    "server": "node src/server.js",
    "backend:dev": "nest start --watch",
    "backend:build": "nest build",
    "backend:start": "node dist/main.js",
    "backend:debug": "nest start --debug --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"{src,tests}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "ui:build": "vite build --config electron/vite.config.mjs",
    "ui:dev": "vite --config electron/vite.config.mjs",
    "test:electron-ui": "yarn ui:build && playwright test",
    "app": "yarn ui:build && electron electron/main.cjs",
    "app:dev": "concurrently -k \"yarn ui:dev\" \"wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.cjs\"",
    "app:dev:win": "yarn app:dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "github",
    "pr",
    "review",
    "automation"
  ],
  "author": {
    "name": "M. Rheza Alfin",
    "email": "m.rheza.alfin@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-ws": "^11.1.16",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.16",
    "acorn": "^8.16.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "cli-spinners": "^3.4.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "execa": "^8.0.1",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "js-yaml": "^4.1.1",
    "json2csv": "^6.0.0-alpha.2",
    "lucide-react": "^0.577.0",
    "markdown-it": "^14.1.1",
    "morgan": "^1.10.1",
    "node-notifier": "^10.0.1",
    "nodemailer": "^8.0.2",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "strip-ansi": "^7.2.0",
    "tailwind-merge": "^3.5.0",
    "terminal-link": "^5.0.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.16",
    "@playwright/test": "^1.58.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^5.1.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "fast-check": "^4.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "tailwindcss": "3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}

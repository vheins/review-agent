# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
WORKSPACE_DIR=./workspace
LOG_LEVEL=info
DRY_RUN=false

# ──────────────────────────────────────────────
# GitHub
# ──────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_USERNAME=

# ──────────────────────────────────────────────
# Review Engine
# ──────────────────────────────────────────────
DELEGATE=false
REVIEW_MODE=comment
REVIEW_INTERVAL=600
AUTO_MERGE=false
PR_SCOPE=authored,assigned,review-requested,involves
STALE_INVOLVES_REVIEW_DAYS=3
EXCLUDE_REPO_OWNERS=

# ──────────────────────────────────────────────
# Issue Sync
# ──────────────────────────────────────────────
ISSUE_SYNC_ENABLED=true
ISSUE_INTERVAL=600
FIX_ISSUE=false

# ──────────────────────────────────────────────
# Severity Scoring
# ──────────────────────────────────────────────
SEVERITY_THRESHOLD=10
SEVERITY_CRITICAL=5
SEVERITY_HIGH=3
SEVERITY_MEDIUM=2
SEVERITY_LOW=1

# ──────────────────────────────────────────────
# AI Executor (gemini, copilot, kiro, claude, codex, opencode)
# ──────────────────────────────────────────────
AI_EXECUTOR=gemini

# ──────────────────────────────────────────────
# Gemini CLI
# ──────────────────────────────────────────────
GEMINI_ENABLED=true
GEMINI_MODEL=auto-3
GEMINI_YOLO=true

# ──────────────────────────────────────────────
# Copilot CLI
# ──────────────────────────────────────────────
COPILOT_ENABLED=false
COPILOT_MODEL=claude-haiku-4.5
COPILOT_YOLO=true

# ──────────────────────────────────────────────
# Kiro CLI
# ──────────────────────────────────────────────
KIRO_ENABLED=false
KIRO_AGENT=auto
KIRO_YOLO=true

# ──────────────────────────────────────────────
# Claude Code CLI
# ──────────────────────────────────────────────
CLAUDE_ENABLED=false
CLAUDE_MODEL=sonnet
CLAUDE_AGENT=
CLAUDE_YOLO=true

# ──────────────────────────────────────────────
# Codex CLI
# ──────────────────────────────────────────────
CODEX_ENABLED=false
CODEX_MODEL=auto
CODEX_YOLO=true

# ──────────────────────────────────────────────
# OpenCode CLI
# ──────────────────────────────────────────────
OPENCODE_ENABLED=false
OPENCODE_MODEL=auto
OPENCODE_AGENT=
OPENCODE_YOLO=true

# ──────────────────────────────────────────────
# Discord Bot
# ──────────────────────────────────────────────
DISCORD_BOT_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=

# ──────────────────────────────────────────────
# Text-to-Speech
# ──────────────────────────────────────────────
TTS_API_URL=http://localhost:20128/v1/audio/speech
TTS_API_KEY=
TTS_INCLUDED_OWNERS=
EXCLUDED_TTS_OWNERS=
TTS_MUTE_START_HOUR=9
TTS_MUTE_END_HOUR=10
